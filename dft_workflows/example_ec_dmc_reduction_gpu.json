      "charge_states": [
        {"state": 0, "charge": 0, "spin": 0, "label": "neutral"},
        {"state": -1, "charge": -1, "spin": 1, "label": "radical anion"}
      ]
    },
    {
      "name": "DMC",
      "geometry_file": "pdb_bank/DMC.pdb",
      "geometry_format": "pdb",
      "residue_names": ["DMC", "DMC1", "DME"],
      "reference_state": 0,
      "charge_states": [
        {"state": 0, "charge": 0, "spin": 0, "label": "neutral"},
        {"state": -1, "charge": -1, "spin": 1, "label": "radical anion"}
      ]
    }
  ]
